{
    "algorithmDefaults": {
        "algorithmType": ["greedy_search", "simulated_annealing"],
        "iterations": {
            "min": 100,
            "max": 100,
            "step": 50
        },
        "randomRate": {
            "min": 0.1,
            "max": 0.1,
            "step": 0.1
        },
        "initialTemp": 100.0,
        "coolingRate": 0.98,
        "minTemp": 0.01,
        "useTimeSeed": true
    },
    "output": {
        "resultsDir": "results",
        "cacheDir": "cache",
        "enableCache": true,
        "saveDetailedLog": false,
        "showPlacementText": false,
        "enableVisualization": true,
        "saveStaticImage": false,
        "logging": {
            "consoleLevel": "INFO",
            "fileLevel": "DEBUG",
            "saveToFile": true
        }
    }
}
