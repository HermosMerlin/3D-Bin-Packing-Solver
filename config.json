{
  "algorithmDefaults": {
    "greedy_search": {
      "iterations": {
        "min": 20,
        "max": 40,
        "step": 20
      },
      "useTimeSeed": false,
      "baseSeed": 42,
      "repeatCount": 1
    },
    "simulated_annealing": {
      "iterations": {
        "min": 20,
        "max": 40,
        "step": 20
      },
      "initialTemp": 50.0,
      "coolingRate": 0.95,
      "minTemp": 0.1,
      "useTimeSeed": false,
      "baseSeed": 42,
      "repeatCount": 1
    }
  },
  "output": {
    "resultsDir": "results",
    "cacheDir": "cache",
    "enableCache": true,
    "cacheVersion": 3,
    "exportSummaryData": true,
    "saveSolutionText": "only-best",
    "saveDetailedLog": false,
    "showPlacementText": false,
    "enableVisualization": true,
    "saveStaticImage": false,
    "analysisCharts": [
      {
        "level": "group",
        "x": "containerAspectRatio",
        "y": "avgFillRate",
        "title": "Container Aspect Ratio vs Avg Fill Rate"
      },
      {
        "level": "group",
        "x": "itemTypeCount",
        "y": "avgFillRate",
        "title": "Item Type Count vs Avg Fill Rate"
      }
    ],
    "logging": {
      "consoleLevel": "INFO",
      "fileLevel": "DEBUG",
      "saveToFile": true
    }
  }
}
